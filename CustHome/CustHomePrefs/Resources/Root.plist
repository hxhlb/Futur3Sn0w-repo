<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<array>
	<dict>
		<key>cell</key>
		<string>PSGroupCell</string>
		<key>footerText</key>
		<string>CustHome backports the modern Home Screen customize experience to iOS 16 and 17. These first prefs let us choose whether the appearance controls drive full system appearance or future icon-only behavior.</string>
	</dict>
	<dict>
		<key>cell</key>
		<string>PSSwitchCell</string>
		<key>default</key>
		<true/>
		<key>defaults</key>
		<string>com.apple.springboard</string>
		<key>key</key>
		<string>CustHomeEnabled</string>
		<key>label</key>
		<string>Enabled</string>
	</dict>
	<dict>
		<key>cell</key>
		<string>PSGroupCell</string>
		<key>footerText</key>
		<string>When set to System Appearance, the Light/Dark/Auto buttons in CustHome continue changing the whole system appearance like they do today. Icon Appearance Only preserves the chosen icon style state for the new pipeline without changing system light/dark mode.</string>
		<key>label</key>
		<string>Appearance Buttons</string>
	</dict>
	<dict>
		<key>cell</key>
		<string>PSLinkListCell</string>
		<key>default</key>
		<integer>0</integer>
		<key>defaults</key>
		<string>com.apple.springboard</string>
		<key>key</key>
		<string>CustHomeAppearanceControlMode</string>
		<key>label</key>
		<string>Drive</string>
		<key>titles</key>
		<array>
			<string>System Appearance</string>
			<string>Icon Appearance Only</string>
		</array>
		<key>values</key>
		<array>
			<integer>0</integer>
			<integer>1</integer>
		</array>
	</dict>
</array>
</plist>
