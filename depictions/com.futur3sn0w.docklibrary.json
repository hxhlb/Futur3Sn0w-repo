      "views": [
        {
          "class": "DepictionSubheaderView",
          "title": "Version 0.4.1",
          "useBoldText": true,
          "useBottomMargin": false
        },
        {
          "class": "DepictionMarkdownTextView",
          "markdown": "\u2022 Fixed App Library category folders closing right after they opened when Close on Launch was enabled",
          "useSpacing": false
        },
        {
          "class": "DepictionSeparatorView"
        },
        {
          "class": "DepictionSubheaderView",
          "title": "Version 0.4.0",
          "useBoldText": true,
          "useBottomMargin": false
        },
        {
          "class": "DepictionMarkdownTextView",
          "markdown": "\u2022 Fixed App Library category groups immediately closing after their open animation",
          "useSpacing": false
        },
        {
          "class": "DepictionMarkdownTextView",
          "markdown": "\u2022 DockLibrary now uses an independent App Library controller for the drawer instead of borrowing SpringBoard's trailing App Library page when possible",
          "useSpacing": false
        },
        {
          "class": "DepictionSeparatorView"
        },
        {
          "class": "DepictionSubheaderView",
          "title": "Version 0.3.0",
          "useBoldText": true,
          "useBottomMargin": false
        },
        {
          "class": "DepictionMarkdownTextView",
          "markdown": "\u2022 Added Swipe Up Anywhere: with it on, a swipe up from anywhere on your home screen opens the drawer, not just from the dock",
          "useSpacing": false
        },
        {
          "class": "DepictionMarkdownTextView",
          "markdown": "\u2022 The drawer follows your finger the same way either way \u2014 it never jumps to meet you, and only opens if you cross the threshold",
          "useSpacing": false
        },
        {
          "class": "DepictionMarkdownTextView",
          "markdown": "\u2022 Added a Fade & Scale animation option: the home screen now scales down slightly as the drawer opens, and back up as it closes, alongside the existing fade",
          "useSpacing": false
        },
        {
          "class": "DepictionSeparatorView"
        },
        {
          "class": "DepictionSubheaderView",
          "title": "Version 0.2.0",
          "useBoldText": true,
          "useBottomMargin": false
        },
        {
          "class": "DepictionMarkdownTextView",
          "markdown": "\u2022 Fixed the floating-style drawer squeezing App Library content to the dock's narrower width, which let it scroll sideways instead of only up/down",
          "useSpacing": false
        },
        {
          "class": "DepictionMarkdownTextView",
          "markdown": "\u2022 Locked out horizontal bounce/scroll on the library's own scroll view as a backup",
          "useSpacing": false
        },
        {
          "class": "DepictionMarkdownTextView",
          "markdown": "\u2022 Immersive style now detects DockFull and squares off the drawer's corners to match it",
          "useSpacing": false
        },
        {
          "class": "DepictionMarkdownTextView",
          "markdown": "\u2022 Immersive style content now clears the notch/Dynamic Island with a bit of top padding, while the backdrop still reaches the very top of the screen",
          "useSpacing": false
        },
        {
          "class": "DepictionSeparatorView"
        }
      ]
    }
